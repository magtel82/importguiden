{
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 6 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.importguiden.se" }],
      "destination": "https://importguiden.se/:path*",
      "permanent": true
    }
  ]
}
